<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RecuperarActivity">
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="42dp"
            android:paddingBottom="32dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="144dp"
                android:layout_height="132dp"
                android:src="@drawable/ic_logo_adoptame_foreground"
                android:scaleType="centerCrop"/>
            <TextView
                android:textSize="38sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:id="@+id/lblTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="AdoptaMe"
                android:letterSpacing="0.02"/>
            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:id="@+id/lblEslogan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Actualiza tu contraseña para seguir ayudando animalitos"
                android:lineSpacingExtra="3dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/ic_login_card_background"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:elevation="8dp">
                <TextView
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/lblRecuperar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recuperar contraseña"
                    android:textAlignment="center"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:id="@+id/lblInformacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Ingresa tu correo y crea una nueva contraseña"
                    android:textAlignment="center"/>
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/lblCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:text="Correo electrónico"/>
                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/txtCorreo"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:hint="Ingresa tu correo"
                    android:singleLine="true"
                    android:inputType="textEmailAddress"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/lblContrasenna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Nueva contraseña"/>
                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/txtContrasenna"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:hint="Ingresa tu nueva contraseña"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:id="@+id/lblContrasenna2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Confirmar contraseña"/>
                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/txtContrasenna2"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:hint="Confirma tu nueva contraseña"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
                <Button
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:id="@+id/btnActualizar"
                    android:background="@drawable/ic_button_primary_background"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="28dp"
                    android:text="Actualizar contraseña"
                    android:textAllCaps="false"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:id="@+id/lblInformacion2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Usa una contraseña segura y fácil de recordar"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="4dp"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="32dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:id="@+id/textViewTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Registrar mascota"/>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:id="@+id/textViewSubtitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ingresa los datos para encontrarle un hogar"
                android:lineSpacingExtra="3dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/ic_login_card_background"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:elevation="8dp">

                <TextView
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Datos del animalito"
                    android:textAlignment="center"/>

                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Completa la información básica para publicarlo en adopción"
                    android:textAlignment="center"/>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Nombre"/>

                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/id_NombreAnimal"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:hint="Ej. Luna, Max, Toby"
                    android:singleLine="true"
                    android:inputType="textCapWords"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Tipo de mascota"/>

                <Spinner
                    android:id="@+id/id_spinnerTipoAnimal"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Raza"/>

                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/id_razaAnimal"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:hint="Ej. Mestizo, labrador, siamés"
                    android:singleLine="true"
                    android:inputType="textCapWords"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Sexo"/>

                <RadioGroup
                    android:id="@+id/id_radioGroupSexo"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/id_radioMacho"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Macho"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/id_radioHembra"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:text="Hembra"/>
                </RadioGroup>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Edad aproximada"/>

                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/id_edadAnimal"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:hint="Ej. 2 años, 6 meses"
                    android:singleLine="true"
                    android:inputType="text"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Descripción"/>

                <EditText
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:id="@+id/id_descripcionAnimal"
                    android:background="@drawable/ic_input_background"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    android:hint="Cuéntanos sobre su personalidad, si es juguetón, tranquilo..."
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Fotos de la mascota" />

                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="La primera foto será la imagen principal. Máximo 5 fotos." />

                <Button
                    android:id="@+id/btnAgregarFoto"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="📷  Agregar foto"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtConteoFotos"
                    android:textSize="13sp"
                    android:textColor="@color/status_disponible"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sin fotos agregadas"
                    android:visibility="gone" />

                <Button
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:id="@+id/id_btnRegistrarAnimal"
                    android:background="@drawable/ic_button_primary_background"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="28dp"
                    android:text="Registrar"
                    android:textAllCaps="false"/>

                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Ayúdalo a encontrar una familia"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>